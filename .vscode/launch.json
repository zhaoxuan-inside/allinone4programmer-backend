{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI (dev)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "FastAPI (prod, no-reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Pytest (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}"],
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Pytest (all tests)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/"],
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        }
    ],
    "compounds": [
        {
            "name": "FastAPI + Tests",
            "configurations": ["FastAPI (dev)", "Pytest (all tests)"]
        }
    ]
}